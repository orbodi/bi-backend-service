#
# Exemple de variables d'environnement pour exécuter les scripts Python SQL Loader.
#
# Utilisation :
# - Sur Windows PowerShell : définis-les dans l'environnement courant (ou crée un vrai `.env` puis charge-le selon ton outil).
# - Le script `003_load_locations_from_csv.py` lit ces variables.
#

PGHOST=localhost
PGPORT=5432
PGDATABASE=bi_database
PGUSER=bi_user
PGPASSWORD=bi_password

